# ============================================================
# Variáveis de produção (Dokploy).
#
# Não commitar este arquivo preenchido. Configurar tudo no painel do
# Dokploy → Project → Environment.
# ============================================================

# ----- Domínio (raiz, sem subdomínio) -----
# Os subdomínios api., app. e auth. são deduzidos a partir deste valor.
# Exemplo: DOMAIN=fatia.app.br → api.fatia.app.br, app.fatia.app.br, auth.fatia.app.br
DOMAIN=fatia.app.br

# ============================================================
# Postgres (criado fora do compose, via Dokploy → Database)
# ============================================================
# Use o hostname interno que o Dokploy gerou (algo como "fatia-postgres")
# OU o IP da rede Docker (visível em "Connection details" do banco).
#
# Crie DUAS databases dentro do mesmo Postgres:
#   - fatia  (aplicação)
#   - logto  (identity provider)
#
# Comandos rápidos depois de criar a "Database" no Dokploy:
#   docker exec -it <postgres-container> psql -U <user> -c 'CREATE DATABASE fatia;'
#   docker exec -it <postgres-container> psql -U <user> -c 'CREATE DATABASE logto;'

# DSN da database principal (usada pelo NestJS / Prisma)
DATABASE_URL=postgresql://fatia:CHANGE_ME@fatia-postgres:5432/fatia

# DSN da database do Logto (mesma instância, database separada)
LOGTO_DB_URL=postgresql://fatia:CHANGE_ME@fatia-postgres:5432/logto

# ============================================================
# Logto (Identity Provider — ADR 008)
# ============================================================

# Versão da imagem svhd/logto. Manter pin pra evitar quebra de breaking change.
LOGTO_VERSION=1.30

# Identifier do "API Resource" criado no console do Logto.
# Use o mesmo valor do subdomínio da API (default: https://api.${DOMAIN})
# Se quiser sobrescrever, descomente:
# LOGTO_AUDIENCE=https://api.fatia.app.br

# Credenciais do "Application" criado no console do Logto, tipo "Traditional Web".
# Preencher após criar a Application no console (auth.${DOMAIN}/admin) na primeira vez.
LOGTO_APP_ID=replace_with_app_id_from_logto_console
LOGTO_APP_SECRET=replace_with_app_secret_from_logto_console

# Secret de 32+ bytes pra criptografar o cookie de sessão do Next.js.
# Gerar: openssl rand -base64 32
LOGTO_COOKIE_SECRET=replace_with_32_byte_random_string

# ============================================================
# Imagens (opcional)
# ============================================================
# Se for buildar via Dokploy direto do Git, deixar default.
# Se for usar registry externo (GHCR/Docker Hub), referenciar aqui.
# API_IMAGE=ghcr.io/seu-usuario/fatia-api:latest
# WEB_IMAGE=ghcr.io/seu-usuario/fatia-web:latest

# ============================================================
# Admin inicial (informativo — usuário criado no console do Logto)
# ============================================================
ADMIN_EMAIL=admin@fatia.app.br
ADMIN_NAME=Admin

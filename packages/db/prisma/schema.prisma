// Fatia — Prisma schema
// Documentação: ../../../docs/ARCHITECTURE.md
// Decisões: ../../../docs/ADR/

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id        String   @id @default(uuid())
  // Sub claim do JWT do Logto. Identidade externa estável (ver ADR 008).
  logtoSub  String   @unique
  email     String   @unique
  name      String
  role      Role     @default(USER)
  timezone  String   @default("America/Sao_Paulo")
  heightCm  Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  goals           UserGoals?
  personalGoals   Goal[]
  meals           Meal[]
  workoutPlans    WorkoutPlan[]
  workoutSessions WorkoutSession[]
  weightLogs      WeightLog[]
  stepLogs        StepLog[]
  waterLogs       WaterLog[]
  customFoods     Food[]     @relation("UserCustomFoods")
  customExercises Exercise[] @relation("UserCustomExercises")
  nutrientTargets NutrientTarget[]

  @@index([logtoSub])
}

enum Role {
  USER
  ADMIN
}

// OAuth facade pro MCP: Logto não expõe DCR público, então a API age
// como AS público (DCR + authorize/token) e federa pro Logto internamente.
model McpOAuthClient {
  id           String   @id @default(uuid())
  clientId     String   @unique
  clientName   String?
  redirectUris String[]
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime?

  authorizations McpOAuthAuthorization[]
}

model McpOAuthAuthorization {
  id                  String    @id @default(uuid())
  // State que mandamos pro Logto — usado no /oauth/callback
  state               String    @unique
  // Code que devolvemos pro cliente MCP (Claude) — preenchido no callback
  code                String?   @unique
  clientId            String
  redirectUri         String
  // State original do cliente MCP — relayed no redirect final
  clientState         String?
  // PKCE enviado pelo cliente MCP — verificado no /oauth/token
  clientCodeChallenge String
  // PKCE que nós usamos com o Logto — usado no token exchange downstream
  logtoCodeVerifier   String
  // Code recebido do Logto no /oauth/callback
  logtoCode           String?
  // resource indicator (RFC 8707), se enviado
  resource            String?
  scope               String?
  expiresAt           DateTime
  consumedAt          DateTime?
  createdAt           DateTime  @default(now())

  client McpOAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)

  @@index([clientId])
  @@index([expiresAt])
}

model UserGoals {
  userId             String   @id
  kcalMin            Int
  kcalMax            Int
  proteinMinG        Int
  proteinMaxG        Int
  carbsMinG          Int
  carbsMaxG          Int
  fatMinG            Int
  fatMaxG            Int
  weeklyWorkouts     Int      @default(3)
  dailyStepsTarget   Int      @default(8000)
  dailyWaterTargetMl Int      @default(2500)
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
// NUTRITION
// ============================================================

model FoodGroup {
  id   Int    @id @default(autoincrement())
  name String @unique // "cereais", "leguminosas", "carnes", "frutas", etc

  foods     Food[]
  mealItems MealItem[]
}

model Food {
  id             Int        @id @default(autoincrement())
  name           String
  source         FoodSource
  groupId        Int?
  // Para CUSTOM foods: dono. Null para TACO/USDA (catálogo público).
  createdByUserId String?
  kcalPer100g    Float
  proteinPer100g Float
  carbsPer100g   Float
  fatPer100g     Float
  // Micronutrientes por 100g (catálogo), mapa flexível: { "sodium_mg": 1.2, "fiber_g": 2.7 }.
  // Derivado por regra de 3 para MealItem.nutrients ao logar (ADR 009).
  nutrients      Json?
  createdAt      DateTime   @default(now())

  group         FoodGroup? @relation(fields: [groupId], references: [id])
  createdBy     User?      @relation("UserCustomFoods", fields: [createdByUserId], references: [id], onDelete: Cascade)
  mealItems     MealItem[]

  // Unicidade por (nome, source) só para públicos. Customs podem repetir nomes
  // entre usuários — unicidade real é (nome, source, createdByUserId).
  @@unique([name, source, createdByUserId])
  @@index([name])
  @@index([source])
  @@index([createdByUserId])
}

enum FoodSource {
  TACO
  USDA
  CUSTOM
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

model Meal {
  id        String   @id @default(uuid())
  userId    String
  mealType  MealType
  eatenAt   DateTime
  notes     String?
  createdAt DateTime @default(now())

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items MealItem[]

  @@index([userId, eatenAt])
}

model MealItem {
  id       String  @id @default(uuid())
  mealId   String
  foodId   Int? // null = item livre estimado pelo Claude
  groupId  Int? // copiado do food, ou inferido pelo Claude
  foodName String // snapshot — sempre preenchido
  grams    Float
  kcal     Float
  proteinG Float
  carbsG   Float
  fatG     Float
  // Micronutrientes opcionais (snapshot), mapa flexível: { "sodium_mg": 412, "sugar_g": 9 }.
  // Json em vez de colunas fixas: nutrientes são open-ended e a TACO não cobre todos
  // (ADR 009). Ausente = não rastreado para aquele item.
  nutrients Json?

  meal  Meal       @relation(fields: [mealId], references: [id], onDelete: Cascade)
  food  Food?      @relation(fields: [foodId], references: [id])
  group FoodGroup? @relation(fields: [groupId], references: [id])

  @@index([mealId])
}

// ============================================================
// WORKOUT
// ============================================================

model Exercise {
  id              Int      @id @default(autoincrement())
  name            String
  muscleGroup     String // "peito", "costas", "pernas", "ombro", "braço", "core", "cardio"
  // Para exercícios custom: dono. Null = catálogo público.
  createdByUserId String?
  createdAt       DateTime @default(now())

  createdBy     User?                 @relation("UserCustomExercises", fields: [createdByUserId], references: [id], onDelete: Cascade)
  planExercises WorkoutPlanExercise[]
  sessionSets   SessionSet[]

  @@unique([name, createdByUserId])
  @@index([name])
  @@index([muscleGroup])
  @@index([createdByUserId])
}

model WorkoutPlan {
  id        String   @id @default(uuid())
  userId    String
  name      String // "Push", "Pull", "Leg"
  createdAt DateTime @default(now())

  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises WorkoutPlanExercise[]
  sessions  WorkoutSession[]

  @@index([userId])
}

model WorkoutPlanExercise {
  id         String @id @default(uuid())
  planId     String
  exerciseId Int
  order      Int
  targetSets Int
  targetReps String // "8-12", "5", "AMRAP" — string pra flexibilidade

  plan     WorkoutPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  exercise Exercise    @relation(fields: [exerciseId], references: [id])

  @@unique([planId, exerciseId])
  @@index([planId])
}

model WorkoutSession {
  id          String    @id @default(uuid())
  userId      String
  planId      String? // null = treino livre
  startedAt   DateTime
  completedAt DateTime?
  notes       String?

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan WorkoutPlan? @relation(fields: [planId], references: [id])
  sets SessionSet[]

  @@index([userId, startedAt])
}

model SessionSet {
  id         String @id @default(uuid())
  sessionId  String
  exerciseId Int
  setNumber  Int

  // Campos de força — opcionais pois SessionSet também cobre cardio
  weightKg Float?
  reps     Int?
  rpe      Float? // 1-10, opcional

  // Campos de cardio — opcionais pois também cobre força
  durationSeconds Int?
  distanceMeters  Float?
  avgHeartRate    Int?
  kcalBurned      Int?

  notes String?

  session  WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise Exercise       @relation(fields: [exerciseId], references: [id])

  @@index([sessionId])
  @@index([exerciseId])
}

// ============================================================
// STEPS
// ============================================================

model StepLog {
  id       String     @id @default(uuid())
  userId   String
  // YYYY-MM-DD no fuso do usuário. String pra evitar ambiguidade de timezone.
  date     String
  steps    Int
  source   StepSource @default(MANUAL)
  loggedAt DateTime   @default(now())
  notes    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Múltiplos logs por dia permitidos (várias fontes, correções, sync parcial).
  // Política de "valor do dia" definida em ADR 007: maior valor entre os logs
  // do dia. Implementada em StepLogService.getStepsForDate.
  @@index([userId, date])
  @@index([userId, loggedAt])
}

enum StepSource {
  MANUAL
  GOOGLE_FIT
  APPLE_HEALTH
  HEALTH_CONNECT
  STRAVA
  GARMIN
  FITBIT
  WEBHOOK
}

// ============================================================
// PROGRESS
// ============================================================

model WeightLog {
  id        String   @id @default(uuid())
  userId    String
  weightKg  Float
  loggedAt  DateTime
  notes     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
}

// Hidratação. Múltiplos logs por dia esperados (cada copo é um log).
// Política do "valor do dia" = SOMA (diferente de StepLog, que é MAX).
model WaterLog {
  id       String   @id @default(uuid())
  userId   String
  // YYYY-MM-DD no fuso do usuário.
  date     String
  ml       Int
  loggedAt DateTime @default(now())
  notes    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, loggedAt])
}

// ============================================================
// PERSONAL GOALS
// ============================================================

// Metas dinâmicas definíveis pelo usuário (via PWA ou Claude/MCP).
// Distintas de `UserGoals` (que cobre só macros nutricionais).
// `currentValue` é derivado em tempo de leitura quando `kind` tem fonte
// (weight, workout_frequency, step_count). Para `body_fat` e `custom`,
// o Claude reporta valores via `lastReportedValue`.
model Goal {
  id                String     @id @default(uuid())
  userId            String
  kind              GoalKind
  title             String
  description       String?
  startValue        Float
  targetValue       Float
  unit              String
  // Reportado pelo Claude para metas sem fonte automática (body_fat, custom).
  lastReportedValue Float?
  deadline          DateTime?
  status            GoalStatus @default(active)
  createdAt         DateTime   @default(now())
  completedAt       DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, kind])
}

enum GoalKind {
  weight
  body_fat
  workout_frequency
  step_count
  custom
}

// Metas de nutrientes personalizadas (ex.: limitar sódio, açúcar; atingir fibra).
// Distintas de `UserGoals` (macros fixos). Min/max em range (ADR 006/D6). O valor
// do dia é agregado de `MealItem.nutrients[nutrientKey]`. Ver ADR 009.
model NutrientTarget {
  id          String   @id @default(uuid())
  userId      String
  nutrientKey String // "sodium_mg", "sugar_g", "fiber_g", "caffeine_mg", ...
  label       String // "Sódio", "Açúcar"
  unit        String // "mg", "g"
  min         Float?
  max         Float?
  period      String   @default("daily") // v1: apenas "daily"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, nutrientKey])
  @@index([userId])
}

enum GoalStatus {
  active
  completed
  expired
  archived
}

# Hoist prisma packages to root node_modules so Docker COPY paths are predictable
# and prisma generate outputs .prisma/client at /app/node_modules/.prisma/client.
# Required for pnpm isolated linker + Prisma (https://pris.ly/d/pnpm-workspaces)
public-hoist-pattern[]=*prisma*
public-hoist-pattern[]=@prisma/*

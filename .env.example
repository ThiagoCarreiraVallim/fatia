# ============================================================
# Banco de dados
# Mesmo Postgres serve a database principal (fatia) e a do Logto (logto).
# ============================================================
POSTGRES_USER=fatia
POSTGRES_PASSWORD=fatia_dev
POSTGRES_DB=fatia
POSTGRES_PORT=5432

DATABASE_URL=postgresql://fatia:fatia_dev@localhost:5432/fatia

# ============================================================
# Logto (Identity Provider — ADR 008)
# ============================================================

# URL pública do Logto. Em desenvolvimento: http://localhost:3001
# Em produção (Dokploy): https://auth.fatia.dominio
LOGTO_ENDPOINT=http://localhost:3001

# URL do console admin do Logto.
# Em produção pode ser uma rota interna ou subdomínio separado.
LOGTO_ADMIN_ENDPOINT=http://localhost:3002

# Portas locais (só usadas em dev local com docker compose).
# Mantém os defaults do Logto pra evitar mismatch entre o admin SPA e a Management API.
LOGTO_PORT=3001
LOGTO_ADMIN_PORT=3002

# ID e secret do "App" criado no console do Logto para o PWA (tipo: Traditional Web).
# Preencher após criar o app no console na primeira vez.
LOGTO_APP_ID=replace_after_creating_app_in_logto_console
LOGTO_APP_SECRET=replace_after_creating_app_in_logto_console

# App "Traditional Web" criado no Logto para o OAuth facade do MCP.
# Redirect URI a configurar no Logto: {API_PUBLIC_URL}/oauth/callback
LOGTO_MCP_APP_ID=replace_after_creating_mcp_app_in_logto_console
LOGTO_MCP_APP_SECRET=replace_after_creating_mcp_app_in_logto_console

# Secret aleatório para criptografar cookies de sessão no Next.js.
# Gerar com: openssl rand -base64 32
LOGTO_COOKIE_SECRET=replace_with_32_byte_random_string

# Base URL do PWA (para callbacks OAuth).
# Em produção: https://app.fatia.dominio
LOGTO_BASE_URL=http://localhost:3030

# Audience que a API NestJS valida nos JWTs.
# Configurar no Logto como "API resource" e usar o identifier aqui.
# Exemplo: https://api.fatia.dominio
LOGTO_AUDIENCE=https://api.fatia.local

# ============================================================
# API
# ============================================================
NODE_ENV=development
API_PORT=3000

# Origem permitida no CORS
WEB_ORIGIN=http://localhost:3030

# ============================================================
# Web
# ============================================================
WEB_PORT=3030
NEXT_PUBLIC_API_URL=http://localhost:3000

# ============================================================
# Admin inicial (apenas referência — usuário criado no console do Logto)
# ============================================================
ADMIN_EMAIL=admin@fatia.local
ADMIN_NAME=Admin
